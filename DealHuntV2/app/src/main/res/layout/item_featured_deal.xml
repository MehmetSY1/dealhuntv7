<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="4dp" app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="14dp" app:cardElevation="0dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <FrameLayout android:layout_width="match_parent" android:layout_height="100dp">
            <ImageView android:id="@+id/ivThumb" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop"/>
            <TextView android:id="@+id/tvSavings" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="top|end" android:layout_margin="6dp" android:background="@drawable/bg_discount_pill" android:paddingHorizontal="8dp" android:paddingVertical="3dp" android:textSize="11sp" android:textColor="@color/accent_orange" android:fontFamily="@font/rajdhani_semibold" android:visibility="gone"/>
            <TextView android:id="@+id/tvPlatformBadge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="bottom|start" android:layout_margin="6dp" android:background="@drawable/bg_best_badge" android:paddingHorizontal="8dp" android:paddingVertical="3dp" android:textSize="10sp" android:textColor="@color/accent_green"/>
        </FrameLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="10dp">
            <TextView android:id="@+id/tvTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="@color/text_primary" android:maxLines="2" android:ellipsize="end" android:layout_marginBottom="6dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/tvSalePrice" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="15sp" android:textColor="@color/accent_green" android:fontFamily="@font/rajdhani_semibold"/>
                <TextView android:id="@+id/tvNormalPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="@color/text_muted"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>