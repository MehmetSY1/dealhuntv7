<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@color/bg_primary">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingHorizontal="20dp" android:paddingTop="48dp" android:paddingBottom="12dp">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="2dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DEAL" android:fontFamily="@font/rajdhani_bold" android:textSize="26sp" android:textColor="@color/text_primary"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HUNT" android:fontFamily="@font/rajdhani_bold" android:textSize="26sp" android:textColor="@color/accent_green"/>
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="30+ platformda canli fiyat karsilastirma" android:textSize="12sp" android:textColor="@color/text_muted" android:layout_marginBottom="14dp"/>
        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
            <EditText android:id="@+id/etSearch" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Oyun ara..." android:textColorHint="@color/text_muted" android:textColor="@color/text_primary" android:textSize="14sp" android:background="@drawable/bg_search" android:paddingHorizontal="18dp" android:paddingEnd="50dp" android:inputType="text" android:imeOptions="actionSearch" android:singleLine="true"/>
            <ImageButton android:id="@+id/btnClear" android:layout_width="42dp" android:layout_height="42dp" android:layout_gravity="end|center_vertical" android:layout_marginEnd="4dp" android:src="@drawable/ic_close" android:background="?attr/selectableItemBackgroundBorderless" android:tint="@color/text_muted" android:visibility="gone" android:contentDescription="Temizle"/>
        </FrameLayout>
    </LinearLayout>
    <ProgressBar android:id="@+id/progressSearch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:visibility="gone"/>
    <TextView android:id="@+id/tvSearchError" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/text_muted" android:gravity="center" android:padding="32dp" android:visibility="gone"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvSearch" android:layout_width="match_parent" android:layout_height="match_parent" android:paddingHorizontal="16dp" android:paddingVertical="8dp" android:clipToPadding="false" android:visibility="gone"/>
    <androidx.core.widget.NestedScrollView android:id="@+id/homeScroll" android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingBottom="16dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="BUNLARI SEVEBILIRSiN" android:textSize="11sp" android:textColor="@color/accent_purple" android:letterSpacing="0.1" android:paddingHorizontal="20dp" android:paddingBottom="10dp"/>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvAiStrip" android:layout_width="match_parent" android:layout_height="200dp" android:paddingHorizontal="12dp" android:clipToPadding="false" android:layout_marginBottom="20dp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="EN IYI FIRSATLAR" android:textSize="11sp" android:textColor="@color/text_muted" android:letterSpacing="0.1" android:paddingHorizontal="20dp" android:paddingBottom="10dp"/>
            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout android:id="@+id/swipeRefresh" android:layout_width="match_parent" android:layout_height="wrap_content">
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvDeals" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingHorizontal="12dp" android:paddingBottom="8dp" android:clipToPadding="false" android:nestedScrollingEnabled="false"/>
            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>