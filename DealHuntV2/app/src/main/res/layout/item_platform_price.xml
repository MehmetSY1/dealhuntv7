<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginVertical="5dp" app:cardBackgroundColor="@color/bg_surface" app:cardCornerRadius="14dp" app:cardElevation="0dp">
    <LinearLayout android:id="@+id/root" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
        <ImageView android:id="@+id/ivStoreLogo" android:layout_width="40dp" android:layout_height="40dp" android:scaleType="centerInside" android:background="@drawable/bg_image_placeholder" android:layout_marginEnd="12dp"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
                <TextView android:id="@+id/tvStoreName" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="15sp" android:textColor="@color/text_primary"/>
                <TextView android:id="@+id/badgeBest" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EN IYI" android:textSize="9sp" android:textColor="@color/accent_green" android:background="@drawable/bg_best_badge" android:paddingHorizontal="8dp" android:paddingVertical="3dp" android:visibility="gone"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/tvOriginalPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="@color/text_muted" android:layout_marginEnd="6dp" android:visibility="gone"/>
                <TextView android:id="@+id/tvDiscount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="@color/accent_orange" android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal">
            <TextView android:id="@+id/tvCurrentPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="18sp" android:textColor="@color/text_primary"  android:layout_marginBottom="4dp"/>
            <Button android:id="@+id/btnBuy" android:layout_width="wrap_content" android:layout_height="32dp" android:text="Al" android:textSize="12sp" android:textColor="@color/bg_primary" android:background="@drawable/bg_small_button" android:paddingHorizontal="12dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>